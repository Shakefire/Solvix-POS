{
  "name": "kbpos",
  "version": "0.1.0",
  "description": "Point of Sales System using Next.js and Electron",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "electron .",
    "pack": "npm run build && electron-builder --win",
    "pack:all": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.5.28",
    "next": "^13.5.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "electron": "^26.6.10",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.kbpos.app",
    "productName": "Solvix POS",
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "out/**/*",
      "node_modules/**/*",
      "assets/**/*"
    ],
    "extraResources": [],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "asar": true,
    "npmRebuild": true,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "icon": "assets/icon.icns"
    },
    "linux": {
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
